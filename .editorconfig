# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*.{js,jsx,ts,tsx}]
end_of_line = lf # Unix-style newlines
indent_style = space
indent_size = 4
charset = utf-8
insert_final_newline = true

[*.css]
end_of_line = lf # Unix-style newlines
indent_style = space
indent_size = 4
charset = utf-8
insert_final_newline = true

[*.{gql,graphql}]
end_of_line = lf # Unix-style newlines
indent_style = space
indent_size = 4
charset = utf-8
insert_final_newline = true
